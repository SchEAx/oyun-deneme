const cn = (...classes: (string | false | null | undefined)[]) => classes.filter(Boolean).join(" ");

type Screen = "menu" | "host" | "join" | "lobby" | "word" | "game" | "result" | "settings";

type Player = { id: string; nick: string; ready: boolean; score: number; word?: string; hint?: string; };

type RoundAssignment = { ownerId: string; targetId: string; word: string; hint: string; };

const randomRoomCode = () => Array.from({ length: 10 }, () => Math.floor(Math.random() * 10)).join("");

const samplePlayers = ["Ali", "Veli", "Mert", "Ayaz"];

const alphabet = "ABCÇDEFGĞHIİJKLMNOÖPRSŞTUÜVYZ".split("");

function shuffle<T>(arr: T[]) { const copy = [...arr]; for (let i = copy.length - 1; i > 0; i--) { const j = Math.floor(Math.random() * (i + 1)); [copy[i], copy[j]] = [copy[j], copy[i]]; } return copy; }

function assignWords(players: Player[]): RoundAssignment[] { const valid = players.filter((p) => p.word && p.hint); const ids = valid.map((p) => p.id); let targets = shuffle(ids);

// nobody gets own word for (let guard = 0; guard < 20; guard++) { if (targets.every((t, i) => t !== ids[i])) break; targets = shuffle(ids); }

// final fallback for 2 players or stubborn shuffle if (!targets.every((t, i) => t !== ids[i]) && ids.length >= 2) { targets = [...ids.slice(1), ids[0]]; }

return valid.map((p, i) => ({ ownerId: p.id, targetId: targets[i], word: p.word || "", hint: p.hint || "", })); }

function maskWord(word: string, guessed: string[]) { return word .split("") .map((ch) => { if (ch === " ") return " "; return guessed.includes(ch.toUpperCase()) ? ch.toUpperCase() : "_"; }) .join(" "); }

export default function KelimeArenasiPrototype() { const [screen, setScreen] = useState<Screen>("menu"); const [roomCode, setRoomCode] = useState(""); const [joinCode, setJoinCode] = useState(""); const [nick, setNick] = useState("Enes"); const [hostId, setHostId] = useState<string>("host-1"); const [players, setPlayers] = useState<Player[]>([]); const [wordInput, setWordInput] = useState(""); const [hintInput, setHintInput] = useState(""); const [round, setRound] = useState(1); const [assignments, setAssignments] = useState<RoundAssignment[]>([]); const [currentWord, setCurrentWord] = useState(""); const [currentHint, setCurrentHint] = useState(""); const [currentOwnerId, setCurrentOwnerId] = useState(""); const [guessed, setGuessed] = useState<string[]>([]); const [wrongLetters, setWrongLetters] = useState<string[]>([]); const [message, setMessage] = useState("İpucuyu dikkatli oku, harfleri akıllıca seç 😎"); const [musicOn, setMusicOn] = useState(true); const [sfxOn, setSfxOn] = useState(true);

const me = players.find((p) => p.id === hostId); const currentOwner = players.find((p) => p.id === currentOwnerId); const revealedWord = useMemo(() => maskWord(currentWord, guessed), [currentWord, guessed]);

const allReady = players.length >= 2 && players.every((p) => p.ready);

const startHostFlow = () => { const code = randomRoomCode(); setRoomCode(code); const mePlayer: Player = { id: "host-1", nick: nick || "Host", ready: false, score: 0, }; const bots: Player[] = samplePlayers.slice(0, 2).map((name, idx) => ({ id: bot-${idx}, nick: name, ready: false, score: 0, })); setPlayers([mePlayer, ...bots]); setScreen("lobby"); };

const startJoinFlow = () => { if (joinCode.trim().length !== 10) return; setRoomCode(joinCode.trim()); const mePlayer: Player = { id: "host-1", nick: nick || "Oyuncu", ready: false, score: 0, }; const others: Player[] = [ { id: "bot-0", nick: "Host", ready: true, score: 0 }, { id: "bot-1", nick: "Mert", ready: false, score: 0 }, ]; setPlayers([mePlayer, ...others]); setScreen("lobby"); };

const toggleReady = () => { setPlayers((prev) => prev.map((p) => (p.id === hostId ? { ...p, ready: !p.ready } : p)) ); };

const fakeReadyOthers = () => { setPlayers((prev) => prev.map((p) => ({ ...p, ready: true }))); };

const goWordPhase = () => { setWordInput(""); setHintInput(""); setScreen("word"); };

const submitWord = () => { if (wordInput.trim().length < 3 || hintInput.trim().length < 2) return;

const updated = players.map((p, idx) => {
  if (p.id === hostId) return { ...p, word: wordInput.trim(), hint: hintInput.trim() };
  const demoWords = [
    { word: "Titanic", hint: "Film" },
    { word: "Ankara", hint: "Şehir" },
    { word: "Kaplan", hint: "Hayvan" },
    { word: "Portekiz", hint: "Ülke" },
  ];
  const pick = demoWords[idx % demoWords.length];
  return { ...p, word: p.word || pick.word, hint: p.hint || pick.hint };
});

const a = assignWords(updated);
const myAssignment = a.find((x) => x.targetId === hostId);

setPlayers(updated);
setAssignments(a);
setCurrentWord(myAssignment?.word.toUpperCase() || "TITANIC");
setCurrentHint(myAssignment?.hint || "Film");
setCurrentOwnerId(myAssignment?.ownerId || updated[1]?.id || "");
setGuessed([]);
setWrongLetters([]);
setRound(1);
setMessage("İlk tur başladı. Başarılar knk 😎");
setScreen("game");

};

const handleGuess = (letter: string) => { if (guessed.includes(letter) || wrongLetters.includes(letter)) return;

if (currentWord.includes(letter)) {
  const nextGuessed = [...guessed, letter];
  setGuessed(nextGuessed);
  setMessage(`Güzel! ${letter} harfi doğru 🔥`);

  const solved = currentWord
    .split("")
    .every((ch) => ch === " " || nextGuessed.includes(ch));

  if (solved) {
    setPlayers((prev) =>
      prev.map((p) => {
        if (p.id === hostId) return { ...p, score: p.score + 50 };
        if (p.id === currentOwnerId) return { ...p, score: p.score + 20 };
        return p;
      })
    );
    setScreen("result");
  }
} else {
  setWrongLetters((prev) => [...prev, letter]);
  setPlayers((prev) =>
    prev.map((p) => {
      if (p.id === hostId) return { ...p, score: p.score - 10 };
      if (p.id === currentOwnerId) return { ...p, score: p.score + 10 };
      return p;
    })
  );
  setMessage(`Ooops... ${letter} yanlış. Kelime sahibine +10, sana -10 😅`);
}

};

const nextRound = () => { if (round >= 5) { setScreen("menu"); setRoomCode(""); setJoinCode(""); setPlayers([]); return; }

const nextIndex = Math.min(round, assignments.length - 1);
const next = assignments[nextIndex];
setRound((r) => r + 1);
setCurrentWord(next.word.toUpperCase());
setCurrentHint(next.hint);
setCurrentOwnerId(next.ownerId);
setGuessed([]);
setWrongLetters([]);
setMessage(`Tur ${round + 1} başladı. Yeni kelime geldi 🚀`);
setScreen("game");

};

